{
  "name": "@universal-config-engine/validator-ajv",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "description": "Ajv JSON Schema validator adapter for Universal Config Engine.",
  "keywords": [
    "config",
    "configuration",
    "ajv",
    "json-schema",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/universal-config-engine.git",
    "directory": "packages/validator-ajv"
  },
  "bugs": {
    "url": "https://github.com/0disoft/universal-config-engine/issues"
  },
  "homepage": "https://github.com/0disoft/universal-config-engine#readme",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "pnpm --filter @universal-config-engine/validator-ajv... build && tsc -p tsconfig.test.json",
    "test": "pnpm --filter @universal-config-engine/validator-ajv... build && vitest run"
  },
  "dependencies": {
    "@universal-config-engine/core": "workspace:*"
  },
  "peerDependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0"
  }
}
