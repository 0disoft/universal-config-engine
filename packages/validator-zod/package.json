{
  "name": "@0disoft/universal-config-engine-validator-zod",
  "version": "0.2.1",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "description": "Zod validator adapter for Universal Config Engine.",
  "keywords": [
    "config",
    "configuration",
    "zod",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/universal-config-engine.git",
    "directory": "packages/validator-zod"
  },
  "bugs": {
    "url": "https://github.com/0disoft/universal-config-engine/issues"
  },
  "homepage": "https://github.com/0disoft/universal-config-engine#readme",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "pnpm --filter @0disoft/universal-config-engine-validator-zod... build && tsc -p tsconfig.test.json",
    "test": "pnpm --filter @0disoft/universal-config-engine-validator-zod... build && vitest run"
  },
  "dependencies": {
    "@0disoft/universal-config-engine-core": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "zod": "^4.4.3"
  }
}
