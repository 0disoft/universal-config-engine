{
  "name": "@0disoft/universal-config-engine-cli",
  "version": "0.5.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "description": "Local CLI for explaining and validating Universal Config Engine pipelines.",
  "keywords": [
    "config",
    "configuration",
    "cli",
    "diagnostics",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/universal-config-engine.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/0disoft/universal-config-engine/issues"
  },
  "homepage": "https://github.com/0disoft/universal-config-engine#readme",
  "bin": {
    "uce": "./dist/main.js"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "pnpm --filter @0disoft/universal-config-engine-cli... build && tsc -p tsconfig.test.json",
    "test": "pnpm --filter @0disoft/universal-config-engine-cli... build && vitest run"
  },
  "dependencies": {
    "@0disoft/universal-config-engine-core": "workspace:*",
    "@0disoft/universal-config-engine-node": "workspace:*",
    "@0disoft/universal-config-engine-validator-ajv": "workspace:*",
    "ajv": "^8.20.0"
  }
}
