{
  "name": "@universal-config-engine/cli",
  "version": "0.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "sideEffects": false,
  "bin": {
    "uce": "./dist/main.js"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "pnpm --filter @universal-config-engine/cli... build && tsc -p tsconfig.test.json",
    "test": "pnpm --filter @universal-config-engine/cli... build && vitest run"
  },
  "dependencies": {
    "@universal-config-engine/core": "workspace:*",
    "@universal-config-engine/node": "workspace:*",
    "@universal-config-engine/validator-ajv": "workspace:*",
    "ajv": "^8.20.0"
  }
}
