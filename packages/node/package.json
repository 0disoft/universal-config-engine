{
  "name": "@0disoft/universal-config-engine-node",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "description": "Node.js JSON file, dotenv file, process env, and argv sources for Universal Config Engine.",
  "keywords": [
    "config",
    "configuration",
    "dotenv",
    "environment",
    "node"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/universal-config-engine.git",
    "directory": "packages/node"
  },
  "bugs": {
    "url": "https://github.com/0disoft/universal-config-engine/issues"
  },
  "homepage": "https://github.com/0disoft/universal-config-engine#readme",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "pnpm --filter @0disoft/universal-config-engine-node... build && tsc -p tsconfig.test.json",
    "test": "pnpm --filter @0disoft/universal-config-engine-node... build && vitest run"
  },
  "dependencies": {
    "@0disoft/universal-config-engine-core": "workspace:*"
  }
}
