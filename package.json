{
  "name": "universal-config-engine-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/universal-config-engine.git"
  },
  "bugs": {
    "url": "https://github.com/0disoft/universal-config-engine/issues"
  },
  "homepage": "https://github.com/0disoft/universal-config-engine#readme",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean:build": "node scripts/clean-build-output.mjs",
    "check:adapter-fixtures": "node scripts/check-adapter-fixtures.mjs",
    "check:release-scripts": "node --test scripts/record-publication-state.test.mjs",
    "check:no-secret-snapshots": "node scripts/check-no-secret-snapshots.mjs",
    "check:api-snapshot": "pnpm run build && node scripts/check-public-api-snapshot.mjs",
    "update:api-snapshot": "pnpm run build && node scripts/check-public-api-snapshot.mjs --update",
    "benchmark:merge-trie": "pnpm --filter @0disoft/universal-config-engine-core build && node scripts/benchmark-merge-trie.mjs",
    "benchmark:argv": "pnpm --filter @0disoft/universal-config-engine-node... build && node scripts/benchmark-argv.mjs",
    "smoke:core-package": "node scripts/smoke-core-package.mjs",
    "smoke:packages": "node scripts/smoke-packages.mjs",
    "smoke:registry-packages": "node scripts/smoke-registry-packages.mjs",
    "check": "pnpm run typecheck && node scripts/check-public-api-snapshot.mjs && pnpm run test && pnpm run check:no-secret-snapshots && pnpm run check:adapter-fixtures && pnpm run check:release-scripts && pnpm run clean:build"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.15",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
